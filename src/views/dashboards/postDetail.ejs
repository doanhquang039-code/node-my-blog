<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= post.title %> - Chi tiết bài viết</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; color: #333; }
        .detail-card { border-radius: 15px; border: none; box-shadow: 0 5px 25px rgba(0,0,0,0.05); background: white; }
        .post-header { border-bottom: 2px solid #f8f9fa; padding-bottom: 20px; margin-bottom: 30px; }
        .post-content-box { line-height: 1.8; font-size: 1.1rem; color: #2c3e50; white-space: pre-wrap; background: #fff; padding: 20px; border-radius: 10px; }
        .media-wrapper { border-radius: 15px; overflow: hidden; background: #000; margin-bottom: 30px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        video, img { width: 100%; max-height: 550px; object-fit: contain; display: block; }
        .info-label { font-size: 0.8rem; text-transform: uppercase; color: #6c757d; font-weight: bold; letter-spacing: 1px; }
        .info-value { font-weight: 600; color: #198754; }
        .comment-box { background: #f8f9fa; border-radius: 12px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #198754; }
    </style>
</head>
<body class="py-5">
    <div class="container">
        <div class="mb-4">
            <a href="/admin/posts" class="btn btn-white border rounded-pill px-4 shadow-sm">
                <i class="bi bi-arrow-left-circle me-2"></i>Quay lại danh sách
            </a>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card detail-card p-4 mb-4">
                    <div class="post-header">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-success px-3 py-2 rounded-pill">
                                <i class="bi bi-folder2-open me-1"></i>
                                <%= post.category ? post.category.name : 'Chưa phân loại' %>
                            </span>
                            <span class="text-muted small">ID: #<%= post.id %></span>
                        </div>
                        <h1 class="fw-bold text-dark mb-3"><%= post.title %></h1>
                    </div>

                    <div class="media-wrapper">
                        <% if (post.video) { %>
                            <video controls poster="<%= post.image %>">
                                <source src="<%= post.video %>" type="video/mp4">
                            </video>
                        <% } else if (post.image) { %>
                            <img src="<%= post.image %>" alt="Hình ảnh">
                        <% } %>
                    </div>

                    <h5 class="fw-bold mb-3">Nội dung chi tiết:</h5>
                    <div class="post-content-box border shadow-sm mb-4"><%= post.content %></div>
                </div>

                <% if (post.status === 'approved') { %>
                    <div class="card detail-card p-4">
                        <h4 class="fw-bold mb-4"><i class="bi bi-chat-left-text me-2"></i>Thảo luận</h4>
                        <form action="/comments/add" method="POST" class="mb-5">
                            <input type="hidden" name="postId" value="<%= post.id %>">
                            <div class="mb-3">
                                <textarea name="content" class="form-control" rows="3" placeholder="Sếp nghĩ gì về bài này?" required></textarea>
                            </div>
                            <button type="submit" class="btn btn-success rounded-pill px-4">Gửi bình luận</button>
                        </form>

                        <div class="comment-list">
                            <% if (post.comments && post.comments.length > 0) { %>
                                <% post.comments.forEach(cmt => { %>
                                    <div class="comment-box shadow-sm" id="cmt-container-<%= cmt.id %>">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="fw-bold text-success"><%= cmt.author ? cmt.author.name : 'Ẩn danh' %></span>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm text-primary p-0" onclick="toggleEdit('<%= cmt.id %>')"><i class="bi bi-pencil-square"></i></button>
                                                <% if (user.role === 'admin' || user.id === cmt.userId) { %>
                                                    <form action="/comments/delete/<%= cmt.id %>" method="POST" onsubmit="return confirm('Xóa nhé sếp?')">
                                                        <button type="submit" class="btn btn-sm text-danger p-0 border-0 bg-transparent"><i class="bi bi-trash"></i></button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </div>
                                        <p id="content-text-<%= cmt.id %>" class="mb-0"><%= cmt.content %></p>
                                        <form id="edit-form-<%= cmt.id %>" action="/comments/update/<%= cmt.id %>" method="POST" class="mt-2 d-none">
                                            <div class="input-group">
                                                <input type="text" name="content" class="form-control" value="<%= cmt.content %>" required>
                                                <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
                                                <button type="button" class="btn btn-secondary btn-sm" onclick="toggleEdit('<%= cmt.id %>')">Hủy</button>
                                            </div>
                                        </form>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p class="text-muted text-center py-4">Chưa có bình luận nào.</p>
                            <% } %>
                        </div>
                    </div>
                <% } else { %>
                    <div class="alert alert-warning rounded-4 border-0 shadow-sm mt-4 text-center">
                        <i class="bi bi-info-circle me-2"></i> Bài viết đang chờ duyệt. Bình luận đang khóa.
                    </div>
                <% } %>
            </div>

            <div class="col-lg-4">
                <div class="card detail-card p-4 sticky-top" style="top: 20px;">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Thông số hệ thống</h5>

                    <div class="mb-4">
                        <p class="info-label mb-1">Tác giả</p>
                        <p class="info-value mb-0"><i class="bi bi-person-check me-1"></i> <%= post.author ? post.author.name : 'Ẩn danh' %></p>
                    </div>

                    <div class="mb-4">
                        <p class="info-label mb-1">Trạng thái</p>
                        <span class="badge <%= post.status === 'pending' ? 'bg-warning text-dark' : 'bg-success' %> w-100 py-2">
                            <%= post.status === 'pending' ? 'ĐANG CHỜ DUYỆT' : 'ĐÃ CÔNG KHAI' %>
                        </span>
                    </div>

                    <% if (post.status === 'approved') { %>
                        <div class="card bg-light border-0 mb-4 p-3 text-center">
                            <div class="d-flex justify-content-around align-items-center mb-3">
                                <div>
                                    <div class="h4 fw-bold mb-0 text-primary"><%= post.stats ? post.stats.view_count : 0 %></div>
                                    <small class="text-muted">Lượt xem</small>
                                </div>
                                <div class="border-start" style="height: 40px;"></div>
                                <div>
                                    <div class="h4 fw-bold mb-0 text-danger"><%= post.stats ? post.stats.like_count : 0 %></div>
                                    <small class="text-muted">Yêu thích</small>
                                </div>
                            </div>
                            <form action="/admin/posts/like/<%= post.id %>" method="POST">
                                <button type="submit" class="btn btn-outline-danger w-100 rounded-pill shadow-sm">
                                    <i class="bi bi-heart-fill me-2"></i> Thả tim ngay
                                </button>
                            </form>
                        </div>
                    <% } else { %>
                        <div class="alert alert-info text-center small rounded-3">
                            <i class="bi bi-lock me-1"></i> Tương tác sẽ mở sau khi duyệt.
                        </div>
                    <% } %>

                    <div class="d-grid gap-2 mt-4">
                        <% if (post.status === 'pending' && (user.role === 'admin' || user.role === 'manager')) { %>
                            <form action="/admin/posts/approve/<%= post.id %>" method="POST">
                                <input type="hidden" name="action" value="approved">
                                <button type="submit" class="btn btn-success w-100 mb-2">Duyệt bài này</button>
                            </form>
                        <% } %>
                        <a href="/admin/posts/edit/<%= post.id %>" class="btn btn-outline-primary rounded-pill">Chỉnh sửa nội dung</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleEdit(id) {
            const text = document.getElementById(`content-text-${id}`);
            const form = document.getElementById(`edit-form-${id}`);
            form.classList.toggle('d-none');
            text.classList.toggle('d-none');
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>