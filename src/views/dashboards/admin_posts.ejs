<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Quản lý Bài viết - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .table-container { border-radius: 15px; overflow: hidden; }
        .status-badge { min-width: 100px; }
    </style>
</head>
<body class="bg-light py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 p-4 bg-white shadow-sm rounded-4 border-start border-success border-5">
            <div>
                <h2 class="fw-bold text-success mb-1"><i class="bi bi-journal-check"></i> QUẢN LÝ BÀI VIẾT</h2>
                <p class="text-muted mb-0">Chào sếp <strong><%= user.name %></strong>. Có <%= posts.length %> bài viết trên hệ thống.</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/admin/posts/create" class="btn btn-success rounded-pill px-4 fw-bold">Viết bài mới</a>
                <a href="/admin/users" class="btn btn-outline-primary rounded-pill px-4 text-decoration-none">Quản lý User</a>
            </div>
        </div>

        <div class="card border-0 shadow-sm table-container">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tiêu đề</th>
                        <th>Tác giả</th>
                        <th>Danh mục</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% posts.forEach(p => { %>
                        <tr>
                            <td class="ps-4 fw-bold"><%= p.title %></td>
                            <td><%= p.author ? p.author.name : 'Ẩn danh' %></td>
                            <td><span class="badge bg-light text-dark border"><%= p.category ? p.category.name : 'Chưa phân loại' %></span></td>
                            <td>
                                <% if(p.status === 'pending') { %>
                                    <span class="badge bg-warning text-dark status-badge">Chờ duyệt</span>
                                <% } else if(p.status === 'approved') { %>
                                    <span class="badge bg-success status-badge">Đã duyệt</span>
                                <% } else { %>
                                    <span class="badge bg-danger status-badge">Bị từ chối</span>
                                <% } %>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <% if (p.status === 'pending' && (user.role === 'admin' || user.role === 'manager')) { %>
                                        <form action="/admin/posts/approve/<%= p.id %>" method="POST" class="d-inline">
                                            <input type="hidden" name="action" value="approved">
                                            <button type="submit" class="btn btn-sm btn-success">Duyệt</button>
                                        </form>
                                    <% } %>
                                    <form action="/admin/posts/delete/<%= p.id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Xóa bài này không sếp?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>