<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Nội dung - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { --admin-green: #198754; --admin-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .table-container { border-radius: 15px; background: white; box-shadow: var(--admin-shadow); border: none; overflow: hidden; }
        .media-box { position: relative; width: 60px; height: 60px; }
        .post-img-thumb { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; border: 1px solid #eee; }
        .video-indicator { position: absolute; bottom: -5px; right: -5px; background: var(--admin-green); color: white; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; font-size: 10px; border: 2px solid white; }
        .nav-pills .nav-link.active { background-color: var(--admin-green); color: white !important; }
        .post-title { color: #2c3e50; text-decoration: none; font-weight: 600; display: block; font-size: 0.95rem; }
        .post-title:hover { color: var(--admin-green); }
        .top-card { border-radius: 15px; border: none; box-shadow: var(--admin-shadow); }
    </style>
</head>
<body class="py-4">
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm border-start border-success border-5">
            <div>
                <h2 class="fw-bold text-success mb-1"><i class="bi bi-journal-richtext me-2"></i>QUẢN LÝ NỘI DUNG</h2>
                <p class="text-muted mb-0">Chào sếp <strong><%= user.name %></strong>. Có <%= approvedPosts.length + pendingPosts.length %> bài viết trên hệ thống.</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/admin/posts/create" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">
                    <i class="bi bi-plus-circle me-2"></i>Viết bài mới
                </a>
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle rounded-pill" data-bs-toggle="dropdown">Báo cáo</button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/admin/posts/export/excel">Xuất Excel</a></li>
                        <li><a class="dropdown-item" href="/admin/posts/export/pdf">Xuất PDF</a></li>
                    </ul>
                </div>
            </div>
        </div>

       <form action="/admin/posts/search" method="GET" class="d-flex mb-4">
    <input type="text" name="author" ...>
    <button type="submit">Tìm</button>
</form>

        <div class="row g-4">
            <div class="col-lg-9">
                <div class="card table-container">
                    <div class="card-header bg-white pt-3 border-0">
                        <ul class="nav nav-pills" id="pills-tab" role="tablist">
                            <li class="nav-item">
                                <button class="nav-link active rounded-pill me-2" data-bs-toggle="pill" data-bs-target="#tab-all">Tất cả</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill me-2 text-success" data-bs-toggle="pill" data-bs-target="#tab-approved">Đã đăng (<%= approvedPosts.length %>)</button>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link rounded-pill text-warning" data-bs-toggle="pill" data-bs-target="#tab-pending">Chờ duyệt (<%= pendingPosts.length %>)</button>
                            </li>
                        </ul>
                    </div>
                    <div class="card-body p-0">
                        <div class="tab-content">
                            <% function renderTable(postList) { %>
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead class="table-light text-secondary small text-uppercase">
                                            <tr>
                                                <th class="ps-4">Media</th>
                                                <th>Nội dung</th>
                                                <th>Tác giả</th>
                                                <th>Thống kê</th>
                                                <th>Trạng thái</th>
                                                <th class="text-end pe-4">Thao tác</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (postList.length > 0) { %>
                                                <% postList.forEach(p => { %>
                                                    <tr>
                                                        <td class="ps-4">
                                                            <div class="media-box">
                                                                <img src="<%= p.image || 'https://via.placeholder.com/150' %>" class="post-img-thumb">
                                                                <% if(p.video) { %><div class="video-indicator"><i class="bi bi-play-fill"></i></div><% } %>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <a href="/admin/posts/view/<%= p.id %>" class="post-title"><%= p.title %></a>
                                                            <small class="text-muted"><%= p.category ? p.category.name : 'Mặc định' %></small>
                                                        </td>
                                                        <td>
                                                            <div class="small fw-bold"><%= p.author ? p.author.name : 'Ẩn danh' %></div>
                                                            <div class="text-muted small"><%= p.createdAt ? new Date(p.createdAt).toLocaleDateString('vi-VN') : '' %></div>
                                                        </td>
                                                        <td>
                                                            <small class="d-block text-primary"><i class="bi bi-eye"></i> <%= p.stats ? p.stats.view_count : 0 %></small>
                                                            <small class="d-block text-danger"><i class="bi bi-heart-fill"></i> <%= p.stats ? p.stats.like_count : 0 %></small>
                                                        </td>
                                                        <td>
                                                            <span class="badge rounded-pill <%= p.status === 'approved' ? 'bg-success' : 'bg-warning text-dark' %>" style="font-size: 0.65rem;">
                                                                <%= p.status === 'approved' ? 'ĐÃ ĐĂNG' : 'CHỜ DUYỆT' %>
                                                            </span>
                                                        </td>
                                                        <td class="text-end pe-4">
                                                            <div class="btn-group">
                                                                <% if (p.status === 'pending' && (user.role === 'admin' || user.role === 'manager')) { %>
                                                                    <form action="/admin/posts/approve/<%= p.id %>" method="POST" class="d-inline">
                                                                        <input type="hidden" name="action" value="approved">
                                                                        <button type="submit" class="btn btn-sm btn-light text-success border-end"><i class="bi bi-check-lg"></i></button>
                                                                    </form>
                                                                <% } %>
                                                                <a href="/admin/posts/view/<%= p.id %>" class="btn btn-sm btn-light border-end"><i class="bi bi-eye"></i></a>
                                                                <a href="/admin/posts/edit/<%= p.id %>" class="btn btn-sm btn-light text-primary border-end"><i class="bi bi-pencil"></i></a>
                                                                <form action="/admin/posts/delete/<%= p.id %>" method="POST" onsubmit="return confirm('Xóa nhé sếp?')">
                                                                    <button type="submit" class="btn btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                                                                </form>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                <% }) %>
                                            <% } else { %>
                                                <tr><td colspan="6" class="text-center py-5 text-muted">Không có bài viết nào.</td></tr>
                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>

                            <div class="tab-pane fade show active" id="tab-all">
                                <% renderTable([...approvedPosts, ...pendingPosts]) %>
                            </div>
                            <div class="tab-pane fade" id="tab-approved">
                                <% renderTable(approvedPosts) %>
                            </div>
                            <div class="tab-pane fade" id="tab-pending">
                                <% renderTable(pendingPosts) %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="card top-card overflow-hidden">
                    <div class="card-header bg-dark text-white py-3">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-fire text-danger me-2"></i>BÀI VIẾT HOT NHẤT</h6>
                    </div>
                    <div class="list-group list-group-flush">
                        <% if(typeof topLiked !== 'undefined' && topLiked.length > 0) { %>
                            <% topLiked.forEach((p, i) => { %>
                                <div class="list-group-item py-3">
                                    <div class="d-flex align-items-start">
                                        <span class="badge bg-light text-dark me-2">#<%= i+1 %></span>
                                        <div class="overflow-hidden">
                                            <a href="/admin/posts/view/<%= p.id %>" class="text-dark text-decoration-none small fw-bold d-block text-truncate"><%= p.title %></a>
                                            <div class="text-danger small" style="font-size: 0.75rem;">
                                                <i class="bi bi-heart-fill me-1"></i><%= p.stats ? p.stats.like_count : 0 %> Tim
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="p-4 text-center text-muted small">Chưa có bài viết nổi bật.</div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>