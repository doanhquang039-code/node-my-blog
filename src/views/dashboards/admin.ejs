<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý Danh mục - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root { --admin-blue: #0d6efd; --admin-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        body { background: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .table-container { border-radius: 15px; background: white; box-shadow: var(--admin-shadow); border: none; overflow: hidden; }
        .top-card { border-radius: 15px; border: none; box-shadow: var(--admin-shadow); }
        .badge-cat { font-size: 0.85rem; padding: 0.5em 1em; border-radius: 50px; }
    </style>
</head>
<body class="py-4">
    <div class="container px-4">
        <div class="d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm border-start border-primary border-5">
            <div>
                <h2 class="fw-bold text-primary mb-1"><i class="bi bi-tags-fill me-2"></i>QUẢN LÝ DANH MỤC</h2>
                <p class="text-muted mb-0">Chào sếp <strong><%= user.name %></strong>. Hiện có <%= categories.length %> danh mục bài viết.</p>
            </div>
            <div class="d-flex gap-2">
                <div class="dropdown">
                    <button class="btn btn-outline-secondary dropdown-toggle rounded-pill shadow-sm" data-bs-toggle="dropdown">
                        <i class="bi bi-download me-1"></i> Xuất báo cáo
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/api/categories/export/excel"><i class="bi bi-file-earmark-spreadsheet me-2 text-success"></i>Excel</a></li>
                        <li><a class="dropdown-item" href="/api/categories/export/pdf"><i class="bi bi-file-earmark-pdf me-2 text-danger"></i>PDF</a></li>
                    </ul>
                </div>
                <a href="/admin/posts" class="btn btn-dark rounded-pill shadow-sm">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại Post
                </a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card top-card p-3">
                    <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-plus-circle me-2"></i>Thêm danh mục</h5>
                    <form action="/api/categories" method="POST">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Tên danh mục</label>
                            <input type="text" id="cat_name" name="name" class="form-control rounded-3" placeholder="Ví dụ: Công nghệ" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Slug (Tự động)</label>
                            <input type="text" id="cat_slug" name="slug" class="form-control rounded-3 bg-light" placeholder="cong-nghe" readonly>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold py-2 shadow-sm">
                            <i class="bi bi-save me-1"></i> LƯU DANH MỤC
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card table-container">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-secondary small text-uppercase">
                                    <tr>
                                        <th class="ps-4">ID</th>
                                        <th>Tên Danh Mục</th>
                                        <th>Slug</th>
                                        <th class="text-end pe-4">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                        <% categories.forEach(cat => { %>
                                            <tr>
                                                <td class="ps-4 text-muted">#<%= cat.id %></td>
                                                <td>
                                                    <span class="badge bg-primary-subtle text-primary badge-cat fw-bold">
                                                        <%= cat.name %>
                                                    </span>
                                                </td>
                                                <td><code class="small">/<%= cat.slug %></code></td>
                                                <td class="text-end pe-4">
                                                    <div class="btn-group shadow-sm">
                                                        <a href="/api/categories/edit/<%= cat.id %>" class="btn btn-sm btn-light border-end" title="Sửa"><i class="bi bi-pencil text-warning"></i></a>
                                                        <form action="/api/categories/delete/<%= cat.id %>" method="POST" class="d-inline" onsubmit="return confirm('Xóa danh mục sẽ ảnh hưởng đến bài viết bài, sếp chắc chứ?')">
                                                            <button type="submit" class="btn btn-sm btn-light" title="Xóa"><i class="bi bi-trash text-danger"></i></button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr><td colspan="4" class="text-center py-5 text-muted fst-italic">Chưa có danh mục nào sếp ơi!</td></tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Script tạo slug tự động chuyên nghiệp hơn
        const nameInput = document.getElementById('cat_name');
        const slugInput = document.getElementById('cat_slug');
        
        nameInput.addEventListener('input', function() {
            let title = nameInput.value;
            let slug = title.toLowerCase()
                .normalize("NFD").replace(/[\u0300-\u036f]/g, "") // Bỏ dấu tiếng Việt
                .replace(/[^\w ]+/g, '') // Bỏ ký tự đặc biệt
                .replace(/ +/g, '-') // Thay khoảng trắng bằng dấu -
                .replace(/-+/g, '-'); // Bỏ dấu - dư thừa
            slugInput.value = slug;
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>