<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Quản lý hệ thống</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="container mt-5">
    <div class="alert alert-danger d-flex justify-content-between align-items-center shadow-sm">
        <h2 class="mb-0"><i class="bi bi-shield-lock"></i> ADMIN PANEL</h2>
        <div class="d-flex gap-2">
            <a href="/admin/users" class="btn btn-primary"><i class="bi bi-people"></i> Quản lý User</a>
            <a href="/logout" class="btn btn-dark">Đăng xuất</a>
        </div>
    </div>
    
    <p class="text-muted">Chào sếp, <strong><%= user.name %></strong>. Sếp đang ở mục <strong>Quản lý Danh mục</strong>.</p>

    <div class="card mt-4 shadow border-danger">
        <div class="card-header bg-danger text-white fw-bold">
            <i class="bi bi-plus-circle"></i> Thêm Danh mục Mới
        </div>
        <div class="card-body">
            <form action="/api/categories" method="POST" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label">Tên danh mục</label>
                    <input type="text" id="cat_name" name="name" class="form-control" placeholder="Ví dụ: Công nghệ" required>
                </div>
                <div class="col-md-5">
                    <label class="form-label">Slug (Đường dẫn)</label>
                    <input type="text" id="cat_slug" name="slug" class="form-control" placeholder="cong-nghe" required>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Lưu ngay</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card mt-5 shadow border-dark">
        <div class="card-header bg-dark text-white fw-bold">
            <i class="bi bi-list-ul"></i> Danh sách Danh mục Hiện có
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Tên Danh Mục</th>
                            <th>Slug</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                            <% categories.forEach(cat => { %>
                                <tr>
                                    <td><%= cat.id %></td>
                                    <td><span class="badge bg-info text-dark"><%= cat.name %></span></td>
                                    <td><code>/<%= cat.slug %></code></td>
                                    <td>
                                       <a href="/api/categories/edit/<%= cat.id %>" class="btn btn-sm btn-warning">Sửa</a>
                                       <form action="/api/categories/delete/<%= cat.id %>" method="POST" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa thật không sếp?')">Xóa</button>
                                       </form>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-4">Chưa có danh mục nào.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Script tạo slug tự động
        const nameInput = document.getElementById('cat_name');
        const slugInput = document.getElementById('cat_slug');
        nameInput.addEventListener('input', function() {
            let title = nameInput.value;
            let slug = title.toLowerCase()
                .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
                .replace(/[^\w ]+/g, '')
                .replace(/ +/g, '-');
            slugInput.value = slug;
        });
    </script>
</body>
</html>