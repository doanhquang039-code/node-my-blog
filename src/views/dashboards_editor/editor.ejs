<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <title>Editor Workspace</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
    />
    <style>
      body {
        background: #fff;
      }
      .editor-nav {
        border-bottom: 1px solid #eee;
      }
      .btn-create {
        background: #6f42c1;
        color: white;
      }
      .btn-create:hover {
        background: #59359a;
        color: white;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg editor-nav py-3">
      <div class="container">
        <a class="navbar-brand fw-bold text-purple" href="/editor"
          ><i class="bi bi-pencil-fill me-2"></i>EDITOR HUB</a
        >
        <div class="d-flex align-items-center gap-3">
          <a
            href="/admin/posts/create"
            class="btn btn-create rounded-pill px-4 shadow-sm"
            >Viết bài mới</a
          >
          <div class="dropdown">
            <button
              class="btn btn-light rounded-circle"
              data-bs-toggle="dropdown"
            >
              <i class="bi bi-person"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/logout">Thoát</a></li>
            </ul>
          </div>
        </div>
      </div>
    </nav>

    <div class="container mt-5">
      <div class="row">
        <div class="col-md-12">
          <h4 class="fw-bold mb-4">Bài viết của sếp</h4>
          <div class="row g-4">
            <div class="col-md-4">
              <div class="card h-100 border-0 shadow-sm p-3">
                <span class="badge bg-warning text-dark mb-2 w-25"
                  >Đang chờ duyệt</span
                >
                <h5 class="fw-bold">Lập trình Node.js cơ bản</h5>
                <p class="text-muted small">Cập nhật lần cuối: 2 giờ trước</p>
                <div class="mt-auto">
                  <a href="#" class="btn btn-sm btn-outline-secondary"
                    >Sửa bài</a
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
