<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bảng điều khiển - <%= user.name %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
    />
    <style>
      body {
        background: #f8f9fa;
        font-family: "Segoe UI", sans-serif;
      }
      .user-header {
        background: linear-gradient(135deg, #198754, #146c43);
        color: white;
        padding: 40px 0;
        border-radius: 0 0 30px 30px;
      }
      .stat-card {
        border: none;
        border-radius: 15px;
        transition: 0.3s;
      }
      .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
      }
      .nav-pills .nav-link.active {
        background-color: #198754;
      }
    </style>
  </head>
  <body>
    <header class="user-header text-center mb-5 shadow">
      <div class="container">
        <i class="bi bi-person-circle fs-1"></i>
        <h2 class="mt-2">Chào sếp, <%= user.name %>!</h2>
        <p class="opacity-75">Thành viên tâm huyết của cộng đồng</p>
        <div class="d-flex justify-content-center gap-2 mt-3">
          <a href="/" class="btn btn-light rounded-pill px-4">Ra trang chủ</a>
          <a href="/logout" class="btn btn-outline-light rounded-pill px-4"
            >Đăng xuất</a
          >
        </div>
      </div>
    </header>

    <div class="container">
      <div class="row g-4">
        <div class="col-lg-4">
          <div class="card stat-card p-4 shadow-sm h-100">
            <h5 class="fw-bold mb-4 border-bottom pb-2">Thông tin của sếp</h5>
            <div class="mb-3">
              <small class="text-muted d-block">Họ và tên</small>
              <strong><%= user.name %></strong>
            </div>
            <div class="mb-3">
              <small class="text-muted d-block">Email đăng ký</small>
              <strong><%= user.email %></strong>
            </div>
            <div class="mb-3">
              <small class="text-muted d-block">Vai trò hệ thống</small>
              <span class="badge bg-success text-uppercase"
                ><%= user.role %></span
              >
            </div>
            <hr />
            <button class="btn btn-outline-primary w-100 rounded-pill">
              Đổi mật khẩu
            </button>
          </div>
        </div>

        <div class="col-lg-8">
          <div class="card stat-card shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 px-4">
              <ul class="nav nav-pills" id="pills-tab" role="tablist">
                <li class="nav-item">
                  <button
                    class="nav-link active rounded-pill"
                    data-bs-toggle="pill"
                    data-bs-target="#tab-comments"
                  >
                    Bình luận của tôi
                  </button>
                </li>
                <li class="nav-item">
                  <button
                    class="nav-link rounded-pill"
                    data-bs-toggle="pill"
                    data-bs-target="#tab-saved"
                  >
                    Đã lưu
                  </button>
                </li>
              </ul>
            </div>
            <div class="card-body p-4">
              <div class="tab-content" id="pills-tabContent">
                <div class="tab-pane fade show active" id="tab-comments">
                  <div class="alert alert-light border shadow-sm">
                    <i class="bi bi-chat-dots me-2"></i> Sếp chưa có bình luận
                    nào. Hãy đi tương tác nhé!
                  </div>
                </div>
                <div class="tab-pane fade" id="tab-saved">
                  <p class="text-muted text-center py-5">
                    Chưa có bài viết nào được lưu.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
